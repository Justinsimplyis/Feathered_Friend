<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <gradient
        android:startColor="?attr/colorSurface"
        android:endColor="?attr/colorBackgroundFloating"
        android:angle="45" />

    <corners android:radius="16dp" />

    <padding
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp" />

    <stroke
        android:width="2dp"
        android:color="?attr/colorOnSurface" />

    <shadowColor android:color="?attr/colorOnSurface" />
</shape>
