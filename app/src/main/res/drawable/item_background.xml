<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <gradient
        android:startColor="?attr/colorSurface"
        android:endColor="?attr/colorBackgroundFloating"
        android:angle="45" />

    <corners android:radius="8dp" />

    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp" />

    <stroke
        android:width="2dp"
        android:color="@color/backgroundColor" />

    <shadowColor android:color="@color/textColorPrimary" />
</shape>

