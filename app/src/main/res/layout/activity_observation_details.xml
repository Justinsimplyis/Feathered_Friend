<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/white"
    tools:context=".ObservationDetailsActivity">


    <ImageView
        android:id="@+id/backArrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_marginBottom="16dp"
        android:contentDescription="Back"
        android:src="@drawable/baseline_arrow_back_24" />


    <TextView
        android:id="@+id/observationTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/backArrow"
        android:layout_marginBottom="8dp"
        android:text="Observation Title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/black" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/observationTitle"
        android:layout_marginVertical="8dp"
        android:background="@android:color/darker_gray" />

    <!-- Observation Details -->
    <TextView
        android:id="@+id/observationDetails"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/observationTitle"
        android:layout_marginTop="16dp"
        android:text="Details about the observation will go here."
        android:textSize="16sp"
        android:textColor="@android:color/black" />

    <!-- Observation Date -->
    <TextView
        android:id="@+id/observationDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/observationDetails"
        android:layout_marginTop="12dp"
        android:text="Date: 01/01/2024"
        android:textSize="16sp"
        android:textColor="@android:color/black" />

    <!-- Observation Location -->
    <TextView
        android:id="@+id/observationLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/observationDate"
        android:layout_marginTop="12dp"
        android:text="Location: Current Location"
        android:textSize="16sp"
        android:textColor="@android:color/black" />

    <!-- Go to Location Button -->
    <Button
        android:id="@+id/goToLocationButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/observationLocation"
        android:layout_marginTop="12dp"
        android:layout_marginStart="8dp"
        android:layout_alignParentStart="true"
        android:text="Go to Location"
        android:backgroundTint="@android:color/holo_blue_light"
        android:textColor="@android:color/white"
        android:padding="8dp" />

    <!-- Buttons Layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="92dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- Delete Button -->
        <Button
            android:id="@+id/deleteObservationButton"
            style="@style/ButtonStyle2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="Delete" />

        <Button
            android:id="@+id/editObservationButton"
            style="@style/ButtonStyle3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Edit"/>
    </LinearLayout>
</RelativeLayout>
